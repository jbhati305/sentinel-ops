SENTINELOPS_DB_PATH=./sentinel_ops.sqlite3
# Set SENTINELOPS_DATABASE_URL to use Postgres instead of SQLite (used by docker-compose.yml)
# SENTINELOPS_DATABASE_URL=postgresql://sentinelops:sentinelops@localhost:5432/sentinelops
SENTINELOPS_SIM_AUTOSTART=1
SENTINELOPS_TICK_SECONDS=1.0
# Optional: publish accepted readings to Grafana Live for WebSocket-backed panels.
# SENTINELOPS_GRAFANA_LIVE_URL=http://localhost:3001/api/live/push/sentinelops
# SENTINELOPS_GRAFANA_LIVE_USERNAME=admin
# SENTINELOPS_GRAFANA_LIVE_PASSWORD=admin
# SENTINELOPS_GRAFANA_LIVE_TOKEN=
# SENTINELOPS_GRAFANA_LIVE_QUEUE_SIZE=5000
