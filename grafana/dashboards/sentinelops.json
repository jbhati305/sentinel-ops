          "rawSql": "SELECT\n  MAX(CASE WHEN d.id = 'cooling-unit-01' THEN COALESCE(h.health_score, 0) END) AS \"CU-01\",\n  MAX(CASE WHEN d.id = 'cooling-unit-02' THEN COALESCE(h.health_score, 0) END) AS \"CU-02\",\n  MAX(CASE WHEN d.id = 'cooling-unit-03' THEN COALESCE(h.health_score, 0) END) AS \"CU-03\",\n  MAX(CASE WHEN d.id = 'cooling-unit-04' THEN COALESCE(h.health_score, 0) END) AS \"CU-04\",\n  MAX(CASE WHEN d.id = 'cooling-unit-05' THEN COALESCE(h.health_score, 0) END) AS \"CU-05\",\n  MAX(CASE WHEN d.id = 'cooling-unit-06' THEN COALESCE(h.health_score, 0) END) AS \"CU-06\"\nFROM devices d\nLEFT JOIN device_health h ON h.device_id = d.id;",
