      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT\n  event_timestamp::timestamptz AS time,\n  value,\n  CASE metric\n    WHEN 'inlet_temperature' THEN 'Inlet'\n    WHEN 'outlet_temperature' THEN 'Outlet'\n    ELSE metric\n  END AS metric\nFROM telemetry_readings\nWHERE device_id = '$device'\n  AND metric IN ('inlet_temperature', 'outlet_temperature')\n  AND event_timestamp::timestamptz BETWEEN $__timeFrom()::timestamptz AND $__timeTo()::timestamptz\nORDER BY time ASC;",
          "refId": "A"
        }
      ],
