      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  d.name AS device,\n  a.severity,\n  a.title,\n  a.evidence_json,\n  a.operator_note,\n  a.resolved_at\nFROM alerts a\nJOIN devices d ON d.id = a.device_id\nWHERE ('$severity' = 'ALL' OR a.severity = '$severity') AND ('$device' = 'ALL' OR '$device' = '$__all' OR a.device_id = '$device')\nORDER BY a.last_detected_at DESC\nLIMIT 30;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
