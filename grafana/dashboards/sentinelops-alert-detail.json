    {
      "id": 4,
      "title": "Current Alert Detail",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "sentinelops-postgres"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 10
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  a.device_id,\n  d.name AS device,\n  a.severity,\n  a.status,\n  a.title,\n  a.confidence,\n  a.explanation,\n  a.recommended_action,\n  a.first_detected_at,\n  a.last_detected_at\nFROM alerts a\nJOIN devices d ON d.id = a.device_id\nWHERE ('$severity' = 'ALL' OR a.severity = '$severity') AND ('$device' = 'ALL' OR '$device' = '$__all' OR a.device_id = '$device')\nORDER BY CASE a.severity WHEN 'CRITICAL' THEN 0 WHEN 'WARNING' THEN 1 ELSE 2 END, a.last_detected_at DESC\nLIMIT 50;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "device"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open device detail",
                    "url": "/d/sentinelops-device-detail/sentinelops-device-detail?var-device=${__data.fields.device_id}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "device_id"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": []
      }
    },
    {
      "id": 5,
      "title": "Alert Activity",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "sentinelops-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT\n  date_trunc('minute', a.first_detected_at::timestamptz) AS time,\n  a.severity AS metric,\n  COUNT(*) AS value\nFROM alerts a\nWHERE ('$severity' = 'ALL' OR a.severity = '$severity') AND ('$device' = 'ALL' OR '$device' = '$__all' OR a.device_id = '$device')\n  AND a.first_detected_at::timestamptz BETWEEN $__timeFrom()::timestamptz AND $__timeTo()::timestamptz\nGROUP BY time, a.severity\nORDER BY time ASC;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#F2495C"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "bars",
            "fillOpacity": 70,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 2,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "title": "Evidence",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "sentinelops-postgres"
